    "Legacy first scene search": "FindFirstObjectByType",
    "Parent MonoBehaviour lookup": "GetComponentsInParent<MonoBehaviour>(true).FirstOrDefault",
    "Project package reference": "com.hpr.fpsdemo",
    "Project package path": "Packages/com.hpr.fpsdemo",
    "Hardcoded local path": "/data/",
    "Embedded local file dependency": "file:../"
