  Id: dialogue_echo_briefing
  DisplayName: Commander Echo
  StartNodeId: echo_start
  Nodes:
  - Id: echo_start
    SpeakerName: Commander Echo
    Text: The hub sentry locked down the north corridor. I need that red keycard
      back and the sentry off the network.
    Choices:
    - Id: echo_accept_security
      Text: I will sweep the corridor.
      NextNodeId: 
      ExitAfterChoice: 1
      StartQuestId: quest_security_sweep
      StatusMessage: Commander Echo marked the security sweep on your HUD.
    - Id: echo_decline
      Text: I need a moment first.
      NextNodeId: 
      ExitAfterChoice: 1
      StartQuestId: 
      StatusMessage: 
